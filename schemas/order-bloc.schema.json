{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BuyBloc order",
  "type": "object",
  "required": [
    "base_price",
    "total_volume"
  ],
  "properties": {
    "base_price": {
      "type": "number",
      "minimum": 0
    },
    "total_volume": {
      "type": "number",
      "minimum": 0
    },
    "max_discount": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "discount_reference_volume": {
      "type": "number",
      "minimum": 0
    }
  }
}
