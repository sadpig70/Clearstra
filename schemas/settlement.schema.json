{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Settlement result",
  "type": "object",
  "required": [
    "buyer_net",
    "seller_net"
  ],
  "properties": {
    "settlement_amount": {
      "type": "number"
    },
    "buyer_net": {
      "type": "number"
    },
    "seller_net": {
      "type": "number"
    },
    "settled_at": {
      "type": "string"
    }
  }
}
