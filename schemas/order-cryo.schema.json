{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CryoFutures order",
  "type": "object",
  "required": [
    "failure_prob",
    "days_to_expiry"
  ],
  "properties": {
    "asset_value": {
      "type": "number",
      "minimum": 0
    },
    "payout_amount": {
      "type": "number",
      "minimum": 0
    },
    "failure_prob": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "days_to_expiry": {
      "type": "number",
      "minimum": 0
    }
  }
}
