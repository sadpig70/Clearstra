{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Clearing allocation result",
  "type": "object",
  "required": [
    "supply",
    "allocations"
  ],
  "properties": {
    "supply": {
      "type": "number",
      "minimum": 0
    },
    "allocated": {
      "type": "number"
    },
    "remaining": {
      "type": "number"
    },
    "allocations": {
      "type": "array",
      "items": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "allocation",
        "type": "object",
        "required": [
          "party_id",
          "amount"
        ],
        "properties": {
          "party_id": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          },
          "priority": {
            "type": "number"
          }
        }
      }
    },
    "requests": {
      "type": "array"
    },
    "cleared_at": {
      "type": "string"
    }
  }
}
